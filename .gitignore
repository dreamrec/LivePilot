# User corpus output (defense in depth — output normally lives at ~/.livepilot/
# atlas-overlays/user/ which is outside the repo, but if a future invocation
# writes into a path inside the repo by accident, these patterns guarantee it
# never gets committed)
.livepilot/
atlas-overlays/user/
**/_inventory.json
**/_canonical.json
**/_clusters.json
**/identity.yaml
corpus_output/
user_corpus_output/
